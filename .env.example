# RAAG Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Google Gemini API Configuration
# ============================================
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyALyxyzFIWVTB3bCC1p1T_Yd1TqVKewa7k

# ============================================
# Docker Compose Configuration
# ============================================
COMPOSE_PROJECT_NAME=raag

# ============================================
# Database Configuration
# ============================================
# MongoDB (already set in docker-compose.yml)
# MONGO_URL=mongodb://admin:password@mongodb:27017

# PostgreSQL (already set in docker-compose.yml)
# DB_HOST=postgres
# DB_USER=admin
# DB_PASSWORD=password
# DB_NAME=raag

# Redis (already set in docker-compose.yml)
# REDIS_URL=redis://redis:6379

# RabbitMQ (already set in docker-compose.yml)
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ============================================
# Service Port Configuration
# ============================================
# API Gateway
API_GATEWAY_PORT=8000

# Individual Services
USER_SERVICE_PORT=8008
INGESTION_SERVICE_PORT=8001
LLM_SERVICE_PORT=8002
QUALITY_SERVICE_PORT=8004
ARCHITECTURE_SERVICE_PORT=8003
AUDIT_SERVICE_PORT=8005
EXPORT_SERVICE_PORT=8006
CHATBOT_SERVICE_PORT=8007

# Frontend
FRONTEND_PORT=3000

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_URL=http://localhost:8000

# ============================================
# LLM Configuration (optional)
# ============================================
# Use local Ollama for offline inference
# OLLAMA_ENDPOINT=http://localhost:11434
# LLM_MODEL=llama2

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO

# ============================================
# Security Configuration (Development Only)
# ============================================
# For production, use strong passwords and secrets
MONGODB_ROOT_PASSWORD=password
POSTGRES_PASSWORD=password
RABBITMQ_DEFAULT_PASS=guest

# ============================================
# Feature Flags
# ============================================
ENABLE_AUDIT_LOGGING=true
ENABLE_PDF_EXPORT=true
ENABLE_REAL_TIME_CHAT=true
ENABLE_ARCHITECTURE_RECOMMENDATIONS=true

# ============================================
# Advanced Configuration
# ============================================
# Rate limiting (requests per minute)
API_RATE_LIMIT=1000

# Cache TTL (seconds)
CACHE_TTL=3600

# Session timeout (seconds)
SESSION_TIMEOUT=86400

# Max request body size
MAX_REQUEST_SIZE=10mb
